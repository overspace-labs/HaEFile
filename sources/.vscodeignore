# --- 源码 & 编译配置 ---
src/**
tsconfig.json
eslint.config.mjs
.prettierrc
.prettierignore

# --- webview-ui 开发文件（仅保留 dist/）---
webview-ui/src/**
webview-ui/*.ts
webview-ui/*.json
webview-ui/*.html
webview-ui/.eslintrc*
webview-ui/.gitignore
webview-ui/node_modules/**

# --- 打包输出目录（避免 build/ 被打包进去）---
build/**

# --- 去掉 source map，减小体积 ---
out/**/*.map
node_modules/**/*.map
node_modules/**/index_vite_proxy.tmp.mjs

# --- 元数据 / 工具 / 临时文件 ---
.git**
.github/**
.vscode**
.vscode-test**
.tmp/**
*.vsix
Makefile
.vscodeignore
.gitignore
**/*.log
**/.DS_Store
